# AWS / S3-Compatible Storage Credentials
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

NUXT_S3_ACCESS_KEY_ID=
NUXT_S3_SECRET_ACCESS_KEY=
NUXT_S3_DEFAULT_REGION=
NUXT_S3_BUCKET=
NUXT_S3_ENDPOINT=

# Example: Cloudflare R2
# NUXT_S3_DEFAULT_REGION=auto
# NUXT_S3_ENDPOINT=https://dafbcc9bb54eab3add9d1b755668cd27.r2.cloudflarestorage.com
# NUXT_S3_BUCKET=your-r2-bucket-name
# NUXT_S3_ACCESS_KEY_ID=your-r2-access-key-id
# NUXT_S3_SECRET_ACCESS_KEY=your-r2-secret-access-key

# Optional: S3-compatible endpoint (MinIO, Cloudflare R2, DigitalOcean Spaces, etc.)
# AWS_ENDPOINT_URL=

# Optional: Default bucket
# DEFAULT_BUCKET=
