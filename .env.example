# AWS / S3-Compatible Storage Credentials
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

NUXT_ACCESS_KEY_ID=
NUXT_SECRET_ACCESS_KEY=
NUXT_DEFAULT_REGION=
NUXT_BUCKET=
NUXT_ENDPOINT=

# Optional: S3-compatible endpoint (MinIO, Cloudflare R2, DigitalOcean Spaces, etc.)
# AWS_ENDPOINT_URL=

# Optional: Default bucket
# DEFAULT_BUCKET=
